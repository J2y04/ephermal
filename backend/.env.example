# ── DATABASE ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ephermal:password@localhost:5432/ephermal
DATABASE_URL_SYNC=postgresql://ephermal:password@localhost:5432/ephermal

# ── REDIS ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# ── SECURITY ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-64-char-random-hex-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
FERNET_KEY=change-me-run-python-cryptography-fernet-generate_key

# ── APP ───────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_URL=https://ephermal.ai
MEDIA_DIR=/var/www/ephermal/media

# ── GOOGLE OAUTH (for login) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://ephermal.ai/api/auth/google/callback

# ── SHOPIFY ───────────────────────────────────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products,read_orders,read_customers,read_analytics,write_pixels
SHOPIFY_REDIRECT_URI=https://ephermal.ai/api/stores/shopify/callback

# ── META (Facebook) ───────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://ephermal.ai/api/stores/meta/callback

# ── GOOGLE ADS ────────────────────────────────────────────────────────────────
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REDIRECT_URI=https://ephermal.ai/api/stores/google/callback

# ── HIGGSFIELD ────────────────────────────────────────────────────────────────
HIGGSFIELD_API_KEY=

# ── STRIPE ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_GROWTH=price_xxx
STRIPE_PRICE_SCALE=price_xxx

# ── N8N ───────────────────────────────────────────────────────────────────────
N8N_URL=http://localhost:5678
N8N_API_KEY=
N8N_ORCHESTRATOR_WEBHOOK=http://localhost:5678/webhook/orchestrator
